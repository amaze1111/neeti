# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────
# Railway provides DATABASE_URL automatically in production
DATABASE_URL=postgresql://user:password@localhost:5432/shasn

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
# Add your iOS app's origin or leave * for development
CORS_ORIGIN=*
